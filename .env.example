# ── Ozon ERP Configuration ────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Application
APP_NAME=Ozon ERP
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-this-to-a-random-string

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./ozon_erp.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ozon_erp

# ── Ozon Seller API Credentials ──────────────────────────────────
# Generate these in your Ozon Seller account → Settings → Seller API
OZON_CLIENT_ID=
OZON_API_KEY=
OZON_BASE_URL=https://api-seller.ozon.ru

# ── DeepSeek Translation ─────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic

# ── Sourcing ─────────────────────────────────────────────────────
OZON_EMBROIDERY_CATEGORY_ID=0  # 刺绣套装类目ID

# ── Rate Limiting ────────────────────────────────────────────────
OZON_RATE_LIMIT_PER_MINUTE=80
OZON_BATCH_DELAY_SECONDS=0.6

# ── Sync Intervals (minutes) ─────────────────────────────────────
SYNC_PRODUCTS_INTERVAL_MINUTES=15
SYNC_PRICES_INTERVAL_MINUTES=5
SYNC_STOCKS_INTERVAL_MINUTES=5
SYNC_FBS_ORDERS_INTERVAL_MINUTES=2
SYNC_FBO_ORDERS_INTERVAL_MINUTES=15
SYNC_FINANCE_INTERVAL_MINUTES=30
SYNC_CATEGORIES_INTERVAL_HOURS=24
